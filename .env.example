# Tavus credentials (required)
TAVUS_API_KEY=sk_...
TAVUS_PERSONA_ID=p...
TAVUS_REPLICA_ID=r1af76e94d00

# Backend / frontend
BACKEND_URL=http://localhost:8001
JITSI_BASE_URL=https://meet.whitelakedigital.com

# --- Kiosk / presence-gating ---
# When KIOSK_MODE=true the web portal skips the login screen and runs in
# presence-driven kiosk mode (attract loop until the controller opens a room).
KIOSK_MODE=false
# SKIP_LOGIN bypasses the username/password gate even outside full kiosk mode.
SKIP_LOGIN=false
# Property is normally read from config.yaml; PROPERTY_NAME overrides it.
PROPERTY_NAME=The Meridian

# Local WebSocket the browser uses to receive controller commands.
# Must match frontend.ws_host / frontend.ws_port in config.yaml.
KIOSK_WS_URL=ws://127.0.0.1:8765
