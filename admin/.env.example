# Laravel admin — copy into your Laravel app's .env and adjust.
APP_NAME="Core X Knowledge Admin"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Same MySQL database the Python runtime writes to (XAMPP defaults shown).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=corex
DB_USERNAME=root
DB_PASSWORD=

# Tavus — used by TavusPublisher to push approved Q&A into the persona context.
TAVUS_API_KEY=sk_...
TAVUS_BASE_URL=https://tavusapi.com/v2
TAVUS_PERSONA_ID=p...
TAVUS_REPLICA_ID=r1af76e94d00
